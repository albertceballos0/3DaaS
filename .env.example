# ============================================================
# .env.example — Copy to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# GCP project
GCP_PROJECT_ID=skillful-air-480018-f2
GCP_REGION=us-central1

# GCS
GCS_BUCKET=bucket-saas-project

# Service account (used by Vertex AI jobs)
GCP_SERVICE_ACCOUNT=custom-models@skillful-air-480018-f2.iam.gserviceaccount.com

# Artifact Registry Docker images
IMAGE_PREPROCESS=us-central1-docker.pkg.dev/skillful-air-480018-f2/nerfstudio-repo/image-preprocess:v2
IMAGE_TRAIN=us-central1-docker.pkg.dev/skillful-air-480018-f2/nerfstudio-repo/image-train-l4:v1

# Ruta local al JSON de la service account (para docker-compose)
# En GCE VM con Workload Identity no se necesita — dejar vacío
GCP_SA_KEY_PATH=./skillful-air-480018-f2-bcb000b8c0e2.json

# Prefect self-hosted — URL del servidor Prefect
# Local:       http://localhost:4200/api
# GCE VM:      http://<IP_INTERNA_VM>:4200/api
PREFECT_API_URL=http://localhost:4200/api
PREFECT_API_KEY=
PREFECT_DEPLOYMENT=gaussian-pipeline/prod
# URL que usa el navegador para conectar a la API de Prefect (usa la IP externa en GCE)
PREFECT_UI_API_URL=http://localhost:4200/api

# Webhook URL to notify Laravel on each pipeline stage change (leave empty to skip)
WEBHOOK_URL=

# GCE VM donde corre el stack Prefect (usado por deploy_vm.sh)
GCE_VM_NAME=3daas-vm
GCE_VM_ZONE=us-central1-a
GCE_VM_USER=
