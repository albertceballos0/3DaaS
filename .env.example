# ============================================================
# .env.example — Copia a .env y rellena los valores.
#
# LOCAL (desarrollo):
#   PREFECT_UI_API_URL=http://localhost:4200/api
#
# PRODUCCIÓN (GCE VM):
#   PREFECT_UI_API_URL=http://<VM_EXTERNAL_IP>:4200/api
#   GCP_SA_KEY_PATH=   ← vacío; la VM usa --scopes=cloud-platform
# ============================================================

# ── Entorno ───────────────────────────────────────────────
# "local" usa la colección Firestore "pipeline_runs_dev"
# "production" usa "pipeline_runs"
APP_ENV=local

# ── GCP ───────────────────────────────────────────────────
GCP_PROJECT_ID=skillful-air-480018-f2
GCP_REGION=us-central1
GCS_BUCKET=bucket-saas-project
GCP_SERVICE_ACCOUNT=custom-models@skillful-air-480018-f2.iam.gserviceaccount.com

# ── Docker images en Artifact Registry ───────────────────
IMAGE_PREPROCESS=us-central1-docker.pkg.dev/skillful-air-480018-f2/nerfstudio-repo/image-preprocess:v2
IMAGE_TRAIN=us-central1-docker.pkg.dev/skillful-air-480018-f2/nerfstudio-repo/image-train-l4:v1

# ── Service account key (local dev únicamente) ────────────
# En producción la VM usa --scopes=cloud-platform → dejar vacío
GCP_SA_KEY_PATH=./skillful-air-480018-f2-bcb000b8c0e2.json

# ── Prefect ───────────────────────────────────────────────
# PREFECT_API_URL: usado fuera de docker-compose (CLI local, scripts manuales)
# Dentro de docker-compose los contenedores usan http://prefect-server:4200/api
PREFECT_API_URL=http://localhost:4200/api

# PREFECT_UI_API_URL: URL que el NAVEGADOR usa para conectar al API de Prefect
# LOCAL:      http://localhost:4200/api
# PRODUCCIÓN: http://<VM_EXTERNAL_IP>:4200/api
PREFECT_UI_API_URL=http://localhost:4200/api

PREFECT_API_KEY=
PREFECT_DEPLOYMENT=gaussian-pipeline/prod

# ── Dataset ───────────────────────────────────────────────
# Subcarpeta GCS para datasets pre-construidos (blender, dnerf, nerfstudio, instant-ngp)
# Si tus datos están en <dataset>/raw/, pon PREBUILT_DATA_SUBFOLDER=raw
PREBUILT_DATA_SUBFOLDER=data

# ── Webhooks ──────────────────────────────────────────────
WEBHOOK_URL=

# ── GCE VM (solo para deploy_vm.sh local) ─────────────────
GCE_VM_NAME=vm-3daas
GCE_VM_ZONE=us-central1-a
GCE_VM_USER=albert_ceballos
